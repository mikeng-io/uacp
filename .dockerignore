# Build-context hygiene for the acceptance/Dockerfile (compose context is the repo root). The
# conformance prober needs the plugin source (skills/, runtime-adapters/, .claude-plugin/, hooks/,
# acceptance/, tests/) — NOT history, caches, worktrees, or local output.
.git
.worktrees
**/__pycache__
**/*.pyc
.venv
acceptance/out
.uacp
# local dev state a fresh user would NOT have — excluding it keeps the reproduction faithful.
.mcp.json
.claude
.claude.json
