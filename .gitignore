__pycache__/
*.py[cod]
*$py.class

# UACP runtime artifacts — generated during execution, not source of truth.
# Under the .uacp/ namespace, the per-phase run dirs are runtime; config.toml
# (knob overrides) and knowledge/ + lessons/ (project-learned corpora) are project-level and tracked.
.uacp/state/
.uacp/proposals/
.uacp/plans/
.uacp/executions/
.uacp/verification/
.uacp/resolutions/
.uacp/bridges/
.uacp/councils/
.uacp/knowledge/indexes/

# Legacy pre-.uacp/ output dir (kept until scratch is cleaned)
.outputs/*

# Worktree isolation — active runs live here, never commit
.worktrees/*

.DS_Store
# In-repo skill bridge: .claude/skills/ -> skills/ symlinks are a LOCAL dev aid so
# Claude Code running in THIS repo discovers UACP's own skills. Not distributed.
# Regenerate: mkdir -p .claude/skills && cd .claude/skills && \
#   for d in ../../skills/uacp-*/; do n=$(basename $d); [ -f $d/SKILL.md ] && ln -sfn ../../skills/$n $n; done && \
#   ln -sfn ../../skills/vendor/code-review-skill code-review-skill
.claude/skills/
.mcp.json
